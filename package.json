{
  "name": "jolin-desktop-pet",
  "version": "1.0.0",
  "description": "Jolin - A desktop pet app based on a real cat",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build:win": "electron-builder --win --x64",
    "build:mac": "electron-builder --mac"
  },
  "build": {
    "appId": "com.jolin.desktoppet",
    "productName": "Jolin",
    "files": [
      "main.js",
      "index.html",
      "renderer.js",
      "assets/**/*"
    ],
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico"
    },
    "mac": {
      "target": "dmg",
      "icon": "assets/icon.icns"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0"
  }
}
